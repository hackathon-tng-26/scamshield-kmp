## Copy this file to local.properties and fill in real values.
## local.properties is gitignored.

sdk.dir=/Users/YOUR_USER/Library/Android/sdk

# ScamShield backend URLs
SCAMSHIELD_API_BASE_URL=http://10.0.2.2:8000
# ^ 10.0.2.2 = Android emulator loopback to host machine
# For physical device, use your LAN IP e.g. http://192.168.1.42:8000
